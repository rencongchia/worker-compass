# Copy to .env and fill in your API keys
# Required: GROQ_API_KEY (free at console.groq.com — no credit card needed)
# Optional: OPENROUTER_API_KEY used as fallback if Groq hits rate limits

# Primary LLM: Llama 3.3-70B via Groq (free tier: 30 RPM, no credits required)
GROQ_API_KEY=your_groq_key_here

# Fallback LLM: Qwen3 via OpenRouter (activated automatically on Groq 429)
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional overrides (defaults shown)
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=https://api.groq.com/openai/v1
# FALLBACK_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# FALLBACK_BASE_URL=https://openrouter.ai/api/v1
# SIMILARITY_THRESHOLD=0.25
